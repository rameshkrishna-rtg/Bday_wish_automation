generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EmailLogs {
  id        Int      @id @default(autoincrement())
  from      String
  to        String
  subject   String
  body      String
  attachments String?
  status    Status
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


enum Status{
  SUCCESS
  FAILED
}